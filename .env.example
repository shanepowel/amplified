# ---------------------------------------------------------------------------
# Amplified — environment variables
# Copy this file to `.env.local` for local development (Cursor),
# and add the same keys in the Vercel dashboard for production.
# ---------------------------------------------------------------------------

# Public site URL (used in emails and absolute links). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://amplified.co.uk

# --- Database (Postgres / Neon) ---------------------------------------------
# Used for consultation requests and AI waste calculator leads.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Sanity CMS -------------------------------------------------------------
# Create a project at https://sanity.io/manage, then fill these in.
# Provisioned project id (Jul 2026): h88io5yf
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# API version is a date; leave as-is unless you know you need a newer one.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Read token (optional) — only needed to preview unpublished/draft content.
SANITY_API_READ_TOKEN=
# Write token — required ONLY to run `npm run seed:sanity` (Editor/Write perms).
SANITY_API_WRITE_TOKEN=

# --- Ask Amplified (OpenAI) -------------------------------------------------
OPENAI_API_KEY=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
# Verified sender domain on Resend; falls back to onboarding@resend.dev.
RESEND_FROM_EMAIL=hello@amplified.co.uk
CONTACT_EMAIL=hello@amplified.co.uk

# --- HubSpot CRM (consultation + newsletter sync; optional) -----------------
HUBSPOT_API_KEY=

# --- Admin API (protects internal dashboard/leads endpoints) --------------
# Required in production. Pass as `Authorization: Bearer <key>` or `x-api-key`.
ADMIN_API_KEY=

# --- TalentHR (careers; optional) -------------------------------------------
TALENTHR_API_KEY=
TALENTHR_DOMAIN=
